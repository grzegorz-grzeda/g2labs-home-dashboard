{
  "name": "g2labs-home-dashboard",
  "version": "1.0.0",
  "description": "Home dashboard for thermometer data from ATC BLE sensors via MQTT",
  "main": "src/server.js",
  "scripts": {
    "build:client": "vite build",
    "start": "npm run build:client && node src/server.js",
    "start:test": "npm run build:client && node src/server.js",
    "bootstrap:mongo": "node scripts/bootstrap-mongo.js",
    "dev": "node --watch src/server.js",
    "dev:client": "vite",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "node --test tests/unit",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.7.0",
    "mqtt": "^5.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.3",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@vitejs/plugin-react": "^4.7.0"
  }
}
